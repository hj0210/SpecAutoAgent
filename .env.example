# ─────────────────────────────────────────────────────────
# SpecAutoAgent 환경변수 설정
# cp .env.example .env 후 값 입력
# 우선순위: USE_AZURE=true > USE_GEMINI=true > OpenAI
# ─────────────────────────────────────────────────────────

# ── 모드 선택 ──────────────────────────────────────────
USE_AZURE=false
USE_GEMINI=true     # 무료 사용 시 true, OpenAI 사용 시 false

# ── Google Gemini (무료 티어, 하루 1,500회) ────────────
# 키 발급: https://aistudio.google.com/apikey (구글 계정으로 바로 가능)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── OpenAI (USE_GEMINI=false, USE_AZURE=false 일 때) ──
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Azure OpenAI (USE_AZURE=true 일 때) ───────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-azure-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01
